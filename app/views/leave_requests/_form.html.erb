<%= form_with model: @leave_request, local: true, html: { multipart: true } do |f| %>
  <% if @leave_request.errors.any? %>
    <div class="alert alert-danger">
      <ul>
        <% @leave_request.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :start_date, class: "form-label" %>
    <%= f.date_field :start_date, class: "form-control", required: true %>
  </div>

  <div class="mb-3">
    <%= f.label :end_date, class: "form-label" %>
    <%= f.date_field :end_date, class: "form-control", required: true %>
  </div>

  <div class="mb-3">
    <%= f.label :reason, class: "form-label" %>
    <%= f.text_area :reason, class: "form-control", rows: 3, required: true %>
  </div>

  <div class="mb-3">
    <%= f.label :file_url, "Upload PDF (optional)", class: "form-label" %>
    <%= f.file_field :file_url, class: "form-control" %>
  </div>

  <%= f.submit "Submit Request", class: "btn btn-primary w-100" %>
<% end %>
