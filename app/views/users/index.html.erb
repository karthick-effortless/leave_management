<h2>All Users</h2>

<table class="table table-hover">
  <thead>
  <tr>
    <th>Name</th>
    <th>Email</th>
    <th>Role</th>
    <th>View</th>
  </tr>
  </thead>
  <tbody>
  <% @users.each do |user| %>
    <tr>
      <td><%= user.name %></td>
      <td><%= user.email %></td>
      <td><%= user.role.capitalize %></td>
      <td><%= link_to "View", user_path(user), class: "btn btn-sm btn-outline-primary" %></td>
    </tr>
  <% end %>
  </tbody>
</table>
