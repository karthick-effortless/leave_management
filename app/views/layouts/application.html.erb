<!DOCTYPE html>
<html>
<head>
  <title>Leave Management System</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-light bg-light mb-4">
  <div class="container">
    <a class="navbar-brand" href="/">LeaveApp</a>
    <div class="ms-auto">
      <% if current_user %>
        <span class="me-2">Signed in as <strong><%= current_user.name %></strong></span>
        <%= link_to "Sign Out", logout_path, method: :delete, data: { turbo: false }, class: "btn btn-outline-danger btn-sm" %>
      <% else %>
        <%= link_to "Login", login_path, class: "btn btn-outline-primary me-2" %>
        <%= link_to "Sign Up", new_user_path, class: "btn btn-outline-success" %>
      <% end %>
    </div>
  </div>
</nav>

<div class="container">
  <% flash.each do |key, message| %>
    <div class="alert alert-<%= key == "notice" ? "success" : "danger" %> alert-dismissible fade show" role="alert" id="flash-message">
      <%= message %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% end %>

  <%= yield %>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<%= javascript_tag do %>
  document.addEventListener("DOMContentLoaded", function() {
  const flash = document.getElementById("flash-message");
  if (flash) {
  setTimeout(() => {
  const bsAlert = bootstrap.Alert.getOrCreateInstance(flash);
  bsAlert.close();
  }, 3000);
  }
  });
<% end %>
</body>
</html>
