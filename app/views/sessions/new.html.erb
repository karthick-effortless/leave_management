<div class="row justify-content-center">
  <div class="col-md-4">
    <div class="card shadow">
      <div class="card-header bg-primary text-white">
        <h4 class="mb-0">Login</h4>
      </div>
      <div class="card-body">
        <%= form_with url: login_path,method: :post,  local: true do |f| %>
          <div class="mb-3">
            <%= f.label :email, class: "form-label" %>
            <%= f.email_field :email, class: "form-control", placeholder: "Email", required: true %>
          </div>
          <div class="mb-3">
            <%= f.label :password, class: "form-label" %>
            <%= f.password_field :password, class: "form-control", placeholder: "Password", required: true %>
          </div>
          <%= f.submit "Login", class: "btn btn-primary w-100" %>
        <% end %>
        <hr>
        <p class="text-center">
          <%= link_to "Sign up now", new_user_path %>
        </p>
      </div>
    </div>
  </div>
</div>
